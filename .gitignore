# Rust / Cargo
src-tauri/target/
src-tauri/gen/
src-tauri/Cargo.lock

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp
*~

# Local debug log (Rust writes JS console messages here)
/tmp/snapcap-debug.log
snapcap-debug.log

# Bundle output (regenerated by CI)
src-tauri/target/release/bundle/

# Tauri signing keys — NEVER commit. Configure these as GitHub repo secrets:
#   TAURI_SIGNING_PRIVATE_KEY
#   TAURI_SIGNING_PRIVATE_KEY_PASSWORD
*.key
!src-tauri/binaries/*.key

# Node / frontend tooling (we currently ship dist/ directly, no bundler)
node_modules/
dist-build/
.pnpm-store/

# Local test assets (not needed in repo)
dist/test.mp4

# Session-local memory (regenerated each /session-end). Don't commit — it
# churns on every session and would pollute git history.
.claude/session-memory.md
